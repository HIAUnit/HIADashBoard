    var popupContent = '<div style="padding:2px"><strong>' + p.code + '</strong><br>' + 
                       p.title + '<br><small style="color:#64748b">' + p.area + '</small></div>';
    marker.bindPopup(popupContent);
    marker.on('mouseover', function(e) { this.openPopup(); });
    marker.on('click', function(e) { openModal(p.code); });
    markersLayer.addLayer(marker);
  });
}

/* Operational Calendar UI Generation Engines */
function buildCalendarGrid() {
  var year = currentCalDate.getFullYear();
  var month = currentCalDate.getMonth();
  
  var monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
  document.getElementById('calendar-month-year').textContent = monthNames[month] + " " + year;
  
  var firstDayIndex = new Date(year, month, 1).getDay();
  var totalDays = new Date(year, month + 1, 0).getDate();
  
  var html = '<div class="cal-day-lbl">S</div><div class="cal-day-lbl">M</div><div class="cal-day-lbl">T</div><div class="cal-day-lbl">W</div><div class="cal-day-lbl">T</div><div class="cal-day-lbl">F</div><div class="cal-day-lbl">S</div>';
  
  for(var i=0; i<firstDayIndex; i++) {
    html += '<div></div>';
  }
  
  for(var day=1; day<=totalDays; day++) {
    var isToday = (day===14 && month===5 && year===2026) ? 'today' : '';
    var hasEvent = COMMITMENTS.some(function(c){return c.day===day && c.month===month && c.year===year}) ? 'has-event' : '';
    
    html += '<div class="cal-cell ' + isToday + ' ' + hasEvent + '" style="cursor:pointer;" onclick="selectCalendarDay(' + day + ')">' + day + '</div>';
  }
  
  document.getElementById('calendar-days-grid').innerHTML = html;
}

function adjustCalendarMonth(offset) {
  currentCalDate.setMonth(currentCalDate.getMonth() + offset);
  closeCalendarAgendaForm();
  buildCalendarGrid();
  renderCommitmentsList();
}

function renderCommitmentsList() {
  var month = currentCalDate.getMonth();
  var year = currentCalDate.getFullYear();
  
  var currentMonthEvents = COMMITMENTS.filter(function(c){ return c.month === month && c.year === year; });
  var container = document.getElementById('commitments-list-box');
  
  if(currentMonthEvents.length === 0) {
    container.innerHTML = '<div style="font-size:11.5px;color:var(--slate-lt);font-style:italic;padding:8px 0;text-align:center;">No direct desk obligations recorded for this cycle.</div>';
    return;
  }
  
  container.innerHTML = currentMonthEvents.map(function(c){
    var monthPillStr = (month+1).toString().padStart(2,'0') + '/' + c.day.toString().padStart(2,'0');
    return '<div class="commitment-card" style="cursor:pointer;" onclick="selectCalendarDay(' + c.day + ')">' +
      '<div class="commit-meta">' +
        '<span class="commit-date">📅 ' + monthPillStr + ' / ' + year + '</span>' +
        '<span class="commit-tag tag-' + c.tag + '">' + c.tag + '</span>' +
      '</div>' +
      '<div class="commit-title">' + c.title + '</div>' +
    '</div>';
  }).join('');
}

/* --- FUNCTIONS FOR HANDLING CALENDAR AGENDA MANAGEMENT --- */
function findCommitmentIndex(day, month, year) {
  return COMMITMENTS.findIndex(function(c) {
    return c.day === day && c.month === month && c.year === year;
  });
}

function selectCalendarDay(day) {
  var month = currentCalDate.getMonth();
  var year = currentCalDate.getFullYear();
  
  document.getElementById('cal-form-day').value = day;
  document.getElementById('cal-form-month').value = month;
  document.getElementById('cal-form-year').value = year;
  
  var monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  document.getElementById('cal-selected-date-lbl').textContent = monthNames[month] + " " + day + ", " + year;
  
  var idx = findCommitmentIndex(day, month, year);
  if (idx !== -1) {
    document.getElementById('cal-input-title').value = COMMITMENTS[idx].title;
    document.getElementById('cal-input-tag').value = COMMITMENTS[idx].tag;
    document.getElementById('btn-del-agenda').style.display = 'inline-block';
  } else {
    document.getElementById('cal-input-title').value = '';
    document.getElementById('cal-input-tag').value = 'review';
    document.getElementById('btn-del-agenda').style.display = 'none';
  }
  
  document.getElementById('calendar-agenda-form-box').style.display = 'block';
}

function saveCalendarAgenda() {
  var day = parseInt(document.getElementById('cal-form-day').value);
  var month = parseInt(document.getElementById('cal-form-month').value);
  var year = parseInt(document.getElementById('cal-form-year').value);
  var title = document.getElementById('cal-input-title').value.trim();
  var tag = document.getElementById('cal-input-tag').value;
  
  if (!title) return alert('Please enter a valid agenda description.');
  
  var idx = findCommitmentIndex(day, month, year);
  if (idx !== -1) {
    COMMITMENTS[idx].title = title;
    COMMITMENTS[idx].tag = tag;
  } else {
    COMMITMENTS.push({ day: day, month: month, year: year, tag: tag, title: title });
  }
  
  closeCalendarAgendaForm();
  buildCalendarGrid();
  renderCommitmentsList();
}

function deleteCalendarAgenda() {
  var day = parseInt(document.getElementById('cal-form-day').value);
  var month = parseInt(document.getElementById('cal-form-month').value);
  var year = parseInt(document.getElementById('cal-form-year').value);
  
  var idx = findCommitmentIndex(day, month, year);
  if (idx !== -1) {
    COMMITMENTS.splice(idx, 1);
  }
  
  closeCalendarAgendaForm();
  buildCalendarGrid();
  renderCommitmentsList();
}

function closeCalendarAgendaForm() {
  document.getElementById('calendar-agenda-form-box').style.display = 'none';
  document.getElementById('cal-input-title').value = '';
}

function snapCurrentTimeline() {
  var now = new Date();
  var offset = now.getTimezoneOffset() * 60000;
  var localISOTime = (new Date(now.getTime() - offset)).toISOString().slice(0, 16);
  var subInput = document.getElementById('m-time-submitted');
  var fwdInput = document.getElementById('m-time-forwarded');
  if(!subInput.value) subInput.value = localISOTime;
  else fwdInput.value = localISOTime;
}

function addCustomTimestampEntry() {
  var nameInp = document.getElementById('m-new-ts-name');
  var valInp = document.getElementById('m-new-ts-val');
  var name = nameInp.value.trim();
  var time = valInp.value;
  
  if(!name || !time) return alert('Please enter both a Milestone Name and Date/Time.');
  
  tempCustomTimestamps.push({ name: name, time: time });
  nameInp.value = '';
  valInp.value = '';
  renderCustomTimestampsList();
}

function deleteCustomTimestampRow(idx) {
  tempCustomTimestamps.splice(idx, 1);
  renderCustomTimestampsList();
}

function renderCustomTimestampsList() {
  var container = document.getElementById('m-custom-ts-container');
  container.innerHTML = tempCustomTimestamps.map(function(t, idx){
    return '<div class="custom-ts-row">' +
      '<span class="custom-ts-label">⏱️ ' + t.name + '</span>' +
      '<div>' +
        '<span class="custom-ts-val">' + fmtDateDisplay(t.time) + '</span>' +
        '<button type="button" class="btn-del-custom-ts" onclick="deleteCustomTimestampRow(' + idx + ')">×</button>' +
      '</div>' +
    '</div>';
  }).join('');
}

function openNewProjectModal() {
  isCreatingNew = true; editingCode = null;
  tempCustomTimestamps = [];
  var nextCode = "HIA-2026-00" + (PROJECTS.length + 1);
  
  document.getElementById('m-code').textContent = nextCode;
  document.getElementById('m-title').textContent = "Register New Development Project";
  document.getElementById('m-input-title').value = '';
  document.getElementById('m-input-proponent').value = '';
  document.getElementById('m-input-cluster').value = 'Energy and Power';
  document.getElementById('m-input-area').value = '';
  document.getElementById('m-input-lat').value = 12.87;
  document.getElementById('m-input-lng').value = 121.77;
  document.getElementById('m-time-submitted').value = '';
  document.getElementById('m-time-forwarded').value = '';
  
  document.getElementById('m-type').value = 'For HIA';
  syncStageOptions();
  document.getElementById('m-focal').value = 'JMDP';
  document.getElementById('m-with').value = 'HIA Secretariat';
  document.getElementById('m-nom').checked = false;
  document.getElementById('m-signing').checked = false;
  document.getElementById('m-hicc').checked = false;
  document.getElementById('m-update').value = 'Project application logged into pipeline storage.';
  
  renderCustomTimestampsList();
  document.getElementById('modal-overlay').classList.add('open');
}

function openModal(code){
  isCreatingNew = false;
  var p=PROJECTS.find(function(x){return x.code===code});
  if(!p)return;
  editingCode=code;
  tempCustomTimestamps = JSON.parse(JSON.stringify(p.customTimestamps || []));
  
  document.getElementById('m-code').textContent=p.code;
  document.getElementById('m-title').textContent="Modify Evaluation Parameters";
  document.getElementById('m-input-title').value = p.title;
  document.getElementById('m-input-proponent').value = p.proponent;
  document.getElementById('m-input-cluster').value = p.cluster;
  document.getElementById('m-input-area').value = p.area;
  document.getElementById('m-input-lat').value = p.lat;
  document.getElementById('m-input-lng').value = p.lng;
  
  document.getElementById('m-time-submitted').value = p.submittedTime || "";
  document.getElementById('m-time-forwarded').value = p.forwardedTime || "";
  
  document.getElementById('m-type').value=p.type;
  syncStageOptions();
  document.getElementById('m-stage').value=p.stage;
  document.getElementById('m-with').value=p.with;
  document.getElementById('m-focal').value=p.focal;
  document.getElementById('m-nom').checked=p.nom;
  document.getElementById('m-signing').checked=p.signing;
  document.getElementById('m-hicc').checked=p.hicc;
  document.getElementById('m-update').value=p.update;
  
  renderCustomTimestampsList();
  document.getElementById('modal-overlay').classList.add('open');
}

function closeModal(e){ document.getElementById('modal-overlay').classList.remove('open'); }

function syncStageOptions(){
  var type=document.getElementById('m-type').value;
  var sel=document.getElementById('m-stage');
  var arr=type==='For Exemption'?STAGES_EXEMPT:STAGES_HIA;
  sel.innerHTML=arr.map(function(s){return '<option>'+s+'</option>'}).join('');
}

function saveProject(){
  var inputTitle = document.getElementById('m-input-title').value.trim();
  if (!inputTitle) return alert('Please input a valid project title.');

  var subTime = document.getElementById('m-time-submitted').value;
  var fwdTime = document.getElementById('m-time-forwarded').value;
  var isProg = inputTitle.toLowerCase().includes('program') || document.getElementById('m-update').value.toLowerCase().includes('program');

  if (isCreatingNew) {
    PROJECTS.unshift({
      code: document.getElementById('m-code').textContent,
      title: inputTitle,
      proponent: document.getElementById('m-input-proponent').value.trim() || 'External Proponent',
      cluster: document.getElementById('m-input-cluster').value,
      area: document.getElementById('m-input-area').value.trim() || 'Philippines',
      lat: parseFloat(document.getElementById('m-input-lat').value) || 12.87,
      lng: parseFloat(document.getElementById('m-input-lng').value) || 121.77,
      type: document.getElementById('m-type').value,
      stage: document.getElementById('m-stage').value,
      with: document.getElementById('m-with').value,
      focal: document.getElementById('m-focal').value,
      nom: document.getElementById('m-nom').checked,
      signing: document.getElementById('m-signing').checked,
      hicc: document.getElementById('m-hicc').checked,
      update: document.getElementById('m-update').value,
      submittedTime: subTime,
      forwardedTime: fwdTime,
      customTimestamps: tempCustomTimestamps,
      isProgram: isProg
    });
  } else {
    var p=PROJECTS.find(function(x){return x.code===editingCode});
    if(p) {
      p.title = inputTitle;
      p.proponent = document.getElementById('m-input-proponent').value.trim();
      p.cluster = document.getElementById('m-input-cluster').value;
      p.area = document.getElementById('m-input-area').value.trim();
      p.lat = parseFloat(document.getElementById('m-input-lat').value) || p.lat;
      p.lng = parseFloat(document.getElementById('m-input-lng').value) || p.lng;
      p.submittedTime = subTime;
      p.forwardedTime = fwdTime;
      p.type=document.getElementById('m-type').value;
      p.stage=document.getElementById('m-stage').value;
      p.with=document.getElementById('m-with').value;
      p.focal=document.getElementById('m-focal').value;
      p.nom=document.getElementById('m-nom').checked;
      p.signing=document.getElementById('m-signing').checked;
      p.hicc=document.getElementById('m-hicc').checked;
      p.update=document.getElementById('m-update').value;
      p.customTimestamps = tempCustomTimestamps;
      p.isProgram = isProg || p.isProgram;
    }
  }
  renderAll();
  closeModal();
}

function filterFocal(f,el){
  document.querySelectorAll('[data-focal]').forEach(function(i){i.classList.remove('active')});
  el.classList.add('active');
  activeFilter.focal=f;
  renderAll();
}
function toggleSidebar(){
  document.getElementById('sidebar').classList.toggle('collapsed');
  document.getElementById('main').classList.toggle('full');
}
function showView(v,el){
  document.getElementById('view-dashboard').style.display = (v==='dashboard') ? 'flex' : 'none';
  document.getElementById('view-table').style.display = (v==='table') ? 'block' : 'none';
}
