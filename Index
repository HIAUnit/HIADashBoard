function filtered(){
  return PROJECTS.filter(function(p){ return activeFilter.focal==='ALL'||p.focal===activeFilter.focal; });
}

function renderKPIs(){
  var ps=PROJECTS;
  document.getElementById('kpis').innerHTML=
    kpiHtml(ps.length,'Total Projects','')+
    kpiHtml(ps.filter(function(p){return p.type==='For HIA'}).length,'For HIA','')+
    kpiHtml(ps.filter(function(p){return p.type==='For Exemption'}).length,'For Exemption','')+
    kpiHtml(ps.filter(function(p){return p.stage==='Monitoring & Evaluation'}).length,'In M&E Stage','highlight')+
    kpiHtml(ps.filter(function(p){return p.nom||p.signing}).length,'Flagged Actions','warn');
}
function kpiHtml(v,l,c){return '<div class="kpi '+c+'"><div class="kpi-val">'+v+'</div><div class="kpi-lbl">'+l+'</div></div>'}

function renderPipeline(){
  var ps=filtered();
  document.getElementById('pipeline').innerHTML=PIPELINE_STAGES.map(function(stage){
    var items=ps.filter(function(p){return p.stage===stage && !p.isProgram});
    var cards=items.length?items.map(function(p){
      var cls='pcard'+(p.type==='For Exemption'?' exempt':'')+(p.stage==='Monitoring & Evaluation'?' me':'')+(p.nom||p.signing?' flagged':'');
      return '<div class="'+cls+'" onclick="openModal(\''+p.code+'\')">'+
        '<div class="pcard-code">'+p.code+'</div>'+
        '<div class="pcard-name">'+p.title+'</div>'+
        '<div class="pcard-meta">'+p.area+'</div>'+
        '<div class="pcard-tags"><span class="tag '+(p.type==='For Exemption'?'tag-exempt':'tag-hia')+'">'+p.type+'</span></div>'+
        '</div>';
    }).join(''):'<div class="empty-col">No projects</div>';
    return '<div class="stage-col"><div class="stage-head-bar"><h3>'+stage+CustomCount(items.length)+'</div><div class="stage-body">'+cards+'</div></div>';
  }).join('');
}
function CustomCount(n){ return '</h3><span class="stage-count">'+n+'</span>'; }

function fmtDateDisplay(dStr) {
  if(!dStr) return '<span style="color:var(--slate-lt)">Not Logged</span>';
  var d = new Date(dStr);
  return d.toLocaleDateString('en-PH', {month:'short', day:'numeric'}) + " " + d.toLocaleTimeString('en-PH', {hour:'2-digit', minute:'2-digit'});
}

function renderTable(){
  var ps = filtered();
  var primaryProjects = ps.filter(function(x){ return !x.isProgram; });
  var devPrograms = ps.filter(function(x){ return x.isProgram; });

  function rowTemplate(p) {
    var customLogsHtml = (p.customTimestamps || []).map(function(t){
      return '<span>⏱️ ' + t.name + ': <strong class="ts-pill">' + fmtDateDisplay(t.time) + '</strong></span>';
    }).join('');

    return '<tr>'+
      '<td><a class="code-link" onclick="openModal(\''+p.code+'\')">'+p.code+'</a></td>'+
      '<td>'+
        '<div style="font-weight:600; color:var(--slate);">'+p.title+'</div>'+
        '<div style="font-size:11px;color:var(--slate-md);font-weight:500;">Proponent: '+p.proponent+'</div>'+
        '<div class="proj-note-line"><strong>Update Note:</strong> '+p.update+'</div>'+
        '<div class="proj-ts-line">'+
          '<span>📬 Submitted: <strong class="ts-pill">'+fmtDateDisplay(p.submittedTime)+'</strong></span>'+
          '<span>🏛️ Forwarded: <strong class="ts-pill">'+fmtDateDisplay(p.forwardedTime)+'</strong></span>'+
          customLogsHtml +
        '</div>'+
      '</td>'+
      '<td>'+p.cluster+'</td><td>'+p.area+'</td>'+
      '<td>'+p.type+'</td>'+
      '<td><strong>'+p.stage+'</strong></td>'+
      '<td>'+p.with+'</td><td>'+p.focal+'</td>'+
      '<td>'+(p.nom?'NOM ':'')+(p.signing?'Signing':'')+'</td>'+
      '<td><button class="edit-icon-btn" onclick="openModal(\''+p.code+'\')">⚙️</button></td>'+
      '</tr>';
  }

  var fullHtml = primaryProjects.map(rowTemplate).join('');
  
  if(devPrograms.length > 0) {
    fullHtml += '<tr class="split-header-row"><td colspan="10">📋 Grouped Development Programs (Strategic Multi-Sector Frameworks)</td></tr>';
    fullHtml += devPrograms.map(rowTemplate).join('');
  }

  document.getElementById('proj-tbody').innerHTML=fullHtml;
  document.getElementById('table-tbody').innerHTML=fullHtml;
}

function renderOSMMarkers() {
