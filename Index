<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>HIA Dashboard — DOH Health Promotion Bureau</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght=400;500;600;700&display=swap" rel="stylesheet">
<!-- Leaflet.js CSS for OpenStreetMap Layering -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --teal:#0F4C5C;--teal-md:#1A6678;--teal-lt:#E8F4F7;
  --slate:#1E293B;--slate-md:#475569;--slate-lt:#94A3B8;
  --paper:#F8FAFC;--white:#FFFFFF;--border:#E2E8F0;
  --amber:#D97706;--amber-lt:#FEF3C7;
  --emerald:#059669;--emerald-lt:#D1FAE5;
  --red:#DC2626;--red-lt:#FEE2E2;
  --blue:#2563EB;--blue-lt:#DBEAFE;
  --violet:#7C3AED;--violet-lt:#EDE9FE;
  --shadow:0 1px 3px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.04);
  --shadow-md:0 4px 6px -1px rgba(0,0,0,.08),0 2px 4px -1px rgba(0,0,0,.04);
  --sidebar-w:220px;
}
body{font-family:'Inter',system-ui,sans-serif;background:var(--paper);color:var(--slate);font-size:14px;line-height:1.5;min-height:100vh}

.sidebar{width:var(--sidebar-w);min-height:100vh;background:var(--teal);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100;transition:transform .25s ease}
.sidebar.collapsed{transform:translateX(calc(-1 * var(--sidebar-w)))}
.sidebar-brand{padding:20px 18px 16px;border-bottom:1px solid rgba(255,255,255,.12)}
.brand-mark{width:36px;height:36px;border:2px solid rgba(255,255,255,.6);border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'DM Serif Display',serif;font-size:13px;color:#fff;margin-bottom:10px}
.brand-name{font-family:'DM Serif Display',serif;font-size:16px;color:#fff;line-height:1.2}
.brand-sub{font-size:10px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.08em;margin-top:2px}

.sidebar-actions{padding:14px 18px 4px}
.btn-add-proj{width:100%;display:flex;align-items:center;justify-content:center;gap:8px;background:var(--emerald);color:#fff;border:none;border-radius:6px;padding:10px 12px;font-size:12.5px;font-weight:600;cursor:pointer;box-shadow:var(--shadow);transition:background .15s}
.btn-add-proj:hover{background:#047857}
.btn-add-proj svg{width:15px;height:15px}

.sidebar-nav{padding:4px 0 16px;flex:1;overflow-y:auto}
.nav-section{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.35);padding:14px 18px 6px}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 18px;font-size:13px;color:rgba(255,255,255,.7);cursor:pointer;transition:background .15s,color .15s;border-left:2px solid transparent;user-select:none}
.nav-item:hover,.nav-item.active{background:rgba(255,255,255,.08);color:#fff;border-left-color:rgba(255,255,255,.5)}
.nav-item svg{width:15px;height:15px;opacity:.7;flex-shrink:0}
.nav-item.active svg{opacity:1}
.sidebar-footer{padding:16px 18px;border-top:1px solid rgba(255,255,255,.1)}
.hiaaps-link{display:flex;align-items:center;gap:8px;padding:9px 12px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:6px;text-decoration:none;color:#fff;font-size:12px;font-weight:600;transition:background .15s}
.hiaaps-link:hover{background:rgba(255,255,255,.18)}
.hiaaps-link svg{width:14px;height:14px;flex-shrink:0}

.main{margin-left:var(--sidebar-w);min-height:100vh;display:flex;flex-direction:column;transition:margin-left .25s ease}
.main.full{margin-left:0}
.topbar{background:var(--white);border-bottom:1px solid var(--border);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;box-shadow:var(--shadow)}
.topbar-left{display:flex;align-items:center;gap:14px}
.toggle-btn{width:36px;height:36px;border:1px solid var(--border);background:var(--white);border-radius:7px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--teal);transition:background .15s,border-color .15s;flex-shrink:0}
.toggle-btn:hover{background:var(--teal-lt);border-color:var(--teal-md)}
.toggle-btn svg{width:18px;height:18px}
.topbar-title{font-family:'DM Serif Display',serif;font-size:18px;color:var(--teal)}
.topbar-right{display:flex;align-items:center;gap:14px}
.ts{font-size:12px;color:var(--slate-lt)}
.refresh-btn{font:600 12px 'Inter',sans-serif;color:var(--teal-md);background:var(--teal-lt);border:1px solid #BFE0E8;border-radius:5px;padding:6px 13px;cursor:pointer;transition:background .15s}
.refresh-btn:hover{background:#D6EBF0}

/* Realignment Layout Strategy */
.content{padding:24px;display:flex;flex-direction:column;gap:24px;}
.top-visualization-grid {display:grid;grid-template-columns:1fr 420px;gap:20px;align-items:stretch;}

/* FIXED LINE BELOW: Swapped justify-content: space-between; with flex-start to remove vertical gap */
.visual-left-stack {display:flex;flex-direction:column;gap:20px;min-width:0;justify-content:flex-start;}

.bottom-registry-box {width:100%;min-width:0;}

.kpi-strip{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}
.kpi{background:var(--white);border:1px solid var(--border);border-radius:8px;padding:14px 16px;box-shadow:var(--shadow)}
.kpi-val{font-family:'DM Serif Display',serif;font-size:28px;color:var(--teal);line-height:1}
.kpi-lbl{font-size:11px;color:var(--slate-md);text-transform:uppercase;letter-spacing:.07em;margin-top:4px}
.kpi.highlight .kpi-val{color:var(--emerald)}
.kpi.warn .kpi-val{color:var(--amber)}

.section-head{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.section-head h2{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--teal);white-space:nowrap}
.section-head::after{content:'';flex:1;height:1px;background:var(--border)}

.pipeline{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
.stage-col{background:var(--white);border:1px solid var(--border);border-radius:8px;overflow:hidden;box-shadow:var(--shadow);min-width:0}
.stage-head-bar{padding:10px 12px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;gap:6px}
.stage-head-bar h3{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--slate-md);line-height:1.3}
.stage-count{font-size:12px;font-weight:700;background:var(--teal-lt);color:var(--teal);padding:2px 7px;border-radius:99px;flex-shrink:0}
.stage-body{padding:8px;display:flex;flex-direction:column;gap:6px;min-height:80px}

.pcard{border:1px solid var(--border);border-left:3px solid var(--teal);border-radius:5px;padding:8px 10px;cursor:pointer;background:#fff;transition:box-shadow .12s,transform .1s;position:relative}
.pcard:hover{box-shadow:var(--shadow-md);transform:translateY(-1px)}
.pcard.exempt{border-left-color:var(--violet)}
.pcard.flagged{border-left-color:var(--amber)}
.pcard.me{border-left-color:var(--emerald)}
.pcard-code{font-size:10px;font-weight:700;color:var(--teal);font-variant-numeric:tabular-nums;letter-spacing:.02em}
.pcard-code.exempt{color:var(--violet)}
.pcard-code.me{color:var(--emerald)}
.pcard-name{font-size:11.5px;font-weight:600;color:var(--slate);line-height:1.3;margin:2px 0}
.pcard-meta{font-size:10px;color:var(--slate-lt);line-height:1.3}
.pcard-tags{display:flex;flex-wrap:wrap;gap:3px;margin-top:5px}
.tag{font-size:9px;font-weight:600;padding:1.5px 6px;border-radius:99px;text-transform:uppercase;letter-spacing:.03em}
.tag-hia{background:var(--teal-lt);color:var(--teal-md)}
.tag-exempt{background:var(--violet-lt);color:var(--violet)}
.empty-col{font-size:12px;color:var(--slate-lt);font-style:italic;padding:10px;text-align:center}

table{width:100%;border-collapse:collapse;background:var(--white);border:1px solid var(--border);border-radius:8px;overflow:hidden;box-shadow:var(--shadow);font-size:12.5px}
thead tr{background:var(--paper);border-bottom:2px solid var(--teal)}
th{padding:10px 12px;text-align:left;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--slate-md);white-space:nowrap}
td{padding:11px 12px;border-bottom:1px solid var(--border);vertical-align:top;line-height:1.45}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--teal-lt)}
td a.code-link{font-weight:700;color:var(--teal);text-decoration:none;font-size:11.5px;cursor:pointer}
td a.code-link:hover{text-decoration:underline}

.split-header-row {background: #f1f5f9 !important; font-weight:700; color:var(--teal); text-transform:uppercase; font-size:11px; letter-spacing:0.05em;}
.split-header-row td {padding:8px 12px; border-bottom: 2px solid #cbd5e1; color: var(--teal-md)}

.proj-note-line {font-size:11px;color:var(--slate-md);margin-top:4px;font-style:italic;background:#f1f5f9;padding:4px 8px;border-radius:4px;border-left:2px solid var(--slate-lt)}
.proj-ts-line {font-size:10.5px;color:var(--slate-md);margin-top:5px;display:flex;flex-wrap:wrap;gap:8px 14px;}
.ts-pill {background:#e2e8f0;padding:1px 6px;border-radius:3px;font-weight:500;color:var(--slate)}

.map-panel{background:var(--white);border:1px solid var(--border);border-radius:8px;padding:16px;box-shadow:var(--shadow);display:flex;flex-direction:column;justify-content:between;}
.map-panel h2{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--teal);margin-bottom:4px}
.map-panel .map-sub{font-size:11px;color:var(--slate-lt);margin-bottom:12px}
#map-container{width:100%;height:420px;border-radius:6px;border:1px solid var(--border);z-index:1}
.map-legend{margin:12px 0 16px;display:grid;grid-template-columns:1fr 1fr;gap:6px;border-bottom:1px dashed var(--border);padding-bottom:12px;}
.legend-item{display:flex;align-items:center;gap:7px;font-size:11px;color:var(--slate-md)}
.legend-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;border:1.5px solid #fff;box-shadow:0 0 0 1px var(--border)}

/* Calendar & Commitment Widget Styles */
.calendar-widget {margin-top:4px;}
.cal-ctrl {display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.cal-month-title {font-size:12px;font-weight:700;color:var(--slate);}
.cal-btn {background:none;border:1px solid var(--border);border-radius:4px;padding:2px 6px;cursor:pointer;font-size:11px;font-weight:600;color:var(--slate-md);}
.cal-btn:hover {background:var(--paper);color:var(--teal);}
.cal-grid {display:grid;grid-template-columns:repeat(7,1fr);gap:4px;text-align:center;font-size:11px;}
.cal-day-lbl {font-weight:700;color:var(--slate-lt);padding-bottom:2px;}
.cal-cell {padding:5px 0;border-radius:4px;color:var(--slate-md);font-weight:500;position:relative;}
.cal-cell.today {background:var(--teal-lt);color:var(--teal);font-weight:700;outline:1px solid var(--teal-md);}
.cal-cell.has-event::after {content:'';position:absolute;bottom:2px;left:50%;transform:translateX(-50%);width:4px;height:4px;border-radius:50%;background:var(--red);}

.commitments-container {margin-top:14px;max-height:190px;overflow-y:auto;display:flex;flex-direction:column;gap:6px;}
.commitment-card {background:var(--paper);border:1px solid var(--border);border-left:3px solid var(--blue);border-radius:4px;padding:6px 8px;display:flex;flex-direction:column;gap:2px;}
.commit-meta {display:flex;justify-content:space-between;align-items:center;font-size:10px;}
.commit-date {color:var(--slate-lt);font-weight:600;}
.commit-tag {font-size:9px;font-weight:700;padding:0.5px 5px;border-radius:3px;text-transform:uppercase;}
.tag-urgent {background:var(--red-lt);color:var(--red);}
.tag-review {background:var(--violet-lt);color:var(--violet);}
.tag-meeting {background:var(--amber-lt);color:var(--amber);}
.commit-title {font-size:11.5px;font-weight:600;color:var(--slate);}

.modal-overlay{display:none;position:fixed;inset:0;background:rgba(15,23,42,.45);z-index:200;align-items:center;justify-content:center;padding:20px}
.modal-overlay.open{display:flex}
.modal{background:#fff;border-radius:10px;width:680px;max-width:100%;max-height:92vh;overflow-y:auto;box-shadow:0 20px 40px rgba(0,0,0,.2)}
.modal-header{padding:20px 24px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:flex-start;background:var(--paper);border-top-left-radius:10px;border-top-right-radius:10px}
.modal-header h2{font-family:'DM Serif Display',serif;font-size:19px;color:var(--teal);line-height:1.2}
.modal-close{background:none;border:none;font-size:24px;color:var(--slate-lt);cursor:pointer;padding:0;line-height:1}
.modal-close:hover{color:var(--slate)}
.modal-body{padding:20px 24px}
.modal-code{font-size:11px;font-weight:700;color:var(--teal);font-variant-numeric:tabular-nums;margin-bottom:4px}
.field-group{margin-bottom:16px}
.field-group label.fl{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--slate-md);margin-bottom:6px}
select,textarea,input[type=text],input[type=number],input[type=datetime-local]{font-family:'Inter',sans-serif;font-size:13px;padding:8px 10px;border:1px solid var(--border);border-radius:6px;width:100%;color:var(--slate);background:#fff;transition:border-color .15s}
select:focus,textarea:focus,input:focus{outline:none;border-color:var(--teal-md);box-shadow:0 0 0 3px rgba(15,76,92,.1)}
textarea{resize:vertical;min-height:60px}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.check-row{font-size:12.5px;font-weight:400;text-transform:none;letter-spacing:0;display:flex;align-items:center;gap:8px;color:var(--slate);cursor:pointer}
.check-row input{width:auto}

.tracking-stepper{background:var(--paper);border:1px solid var(--border);border-radius:8px;padding:14px 16px;margin-bottom:16px;display:flex;flex-direction:column;gap:12px}
.stepper-header-wrap {display:flex;justify-content:space-between;align-items:center;}
.stepper-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--teal);flex:1;}
.btn-snap-ts {background:var(--teal-lt);color:var(--teal-md);border:1px solid #BFE0E8;font-size:11px;font-weight:600;padding:2px 8px;border-radius:4px;cursor:pointer;}
.btn-snap-ts:hover {background:#D6EBF0}
.step-item{display:grid;grid-template-columns:24px 1fr;gap:10px;align-items:start;position:relative}
.step-icon{width:20px;height:20px;border-radius:50%;background:var(--border);color:var(--slate-md);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;z-index:2}
.step-item.filled .step-icon{background:var(--teal-lt);color:var(--teal-md);border:1px solid var(--teal-md)}
.step-content{display:flex;justify-content:space-between;align-items:center;gap:10px}
.step-label{font-size:12px;font-weight:600;color:var(--slate-md)}
.step-input-wrap{width:220px;flex-shrink:0}

.custom-ts-row {background:#fff; border:1px dashed var(--border); border-radius:6px; padding:8px 10px; display:flex; justify-content:space-between; align-items:center; gap:8px;}
.custom-ts-label {font-size:11.5px; font-weight:600; color:var(--slate-md);}
.custom-ts-val {font-size:11px; color:var(--teal); background:var(--teal-lt); padding:2px 6px; border-radius:4px; font-weight:700;}
.btn-del-custom-ts {background:none; border:none; color:var(--red); font-size:14px; cursor:pointer;}

.add-custom-ts-box {background:#edf2f7; border-radius:6px; padding:10px; display:grid; grid-template-columns:1fr 1fr auto; gap:8px; align-items:end; margin-top:4px;}

.modal-footer{padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;gap:12px}
.btn{font:600 13px 'Inter',sans-serif;padding:9px 18px;border-radius:6px;cursor:pointer;border:none;transition:background .15s,transform .1s}
.btn:active{transform:scale(.98)}
.btn-primary{background:var(--teal);color:#fff}
.btn-primary:hover{background:var(--teal-md)}
.btn-ghost{background:var(--paper);color:var(--slate-md);border:1px solid var(--border)}
.btn-ghost:hover{background:var(--border)}

.edit-icon-btn {background:none;border:none;cursor:pointer;font-size:14px;}
.leaflet-popup-content{font-family:'Inter',sans-serif;font-size:12px;line-height:1.4}
</style>
</head>
<body>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <div class="brand-mark">HIA</div>
    <div class="brand-name">Health Impact Assessment</div>
    <div class="brand-sub">DOH · Health Promotion Bureau</div>
  </div>
  <div class="sidebar-actions">
    <button class="btn-add-proj" onclick="openNewProjectModal()">
      <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
      Add New Project
    </button>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section">View</div>
    <div class="nav-item active" data-nav onclick="showView('dashboard',this)">
      <svg viewBox="0 0 20 20" fill="currentColor"><path d="M3 4a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 7a1 1 0 011-1h3a1 1 0 011 1v5a1 1 0 01-1 1H4a1 1 0 01-1-1v-5zm7-7a1 1 0 011-1h5a1 1 0 011 1v5a1 1 0 01-1 1h-5a1 1 0 01-1-1V4zm0 9a1 1 0 011-1h5a1 1 0 011 1v3a1 1 0 01-1 1h-5a1 1 0 01-1-1v-3z"/></svg>
      Dashboard
    </div>
    <div class="nav-item" data-nav onclick="showView('table',this)">
      <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5 4a3 3 0 00-3 3v6a3 3 0 003 3h10a3 3 0 003-3V7a3 3 0 00-3-3H5zm-1 9v-1h5v2H5a1 1 0 01-1-1zm7 1h4a1 1 0 001-1v-1h-5v2zm0-4h5V8h-5v2zM9 8H4v2h5V8z" clip-rule="evenodd"/></svg>
      All Projects
    </div>
    <div class="nav-section">Focal</div>
    <div class="nav-item active" data-focal onclick="filterFocal('ALL',this)">All Focals</div>
    <div class="nav-item" data-focal onclick="filterFocal('JMDP',this)">Michael (JMDP)</div>
    <div class="nav-item" data-focal onclick="filterFocal('LACM',this)">Lanze (LACM)</div>
  </nav>
  <div class="sidebar-footer">
    <a href="https://hiaaps.doh.gov.ph" target="_blank" rel="noopener" class="hiaaps-link">
      <svg viewBox="0 0 20 20" fill="currentColor"><path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"/><path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"/></svg>
      Open HIAApS
    </a>
  </div>
</aside>

<main class="main" id="main">
  <div class="topbar">
    <div class="topbar-left">
      <button class="toggle-btn" id="toggleBtn" onclick="toggleSidebar()">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/></svg>
      </button>
      <div class="topbar-title">Project Review Dashboard</div>
    </div>
    <div class="topbar-right">
      <span class="ts">Updated <span id="ts-date"></span></span>
      <button class="refresh-btn" onclick="location.reload()">Refresh</button>
    </div>
  </div>

  <div id="view-dashboard" class="content">
    
    <!-- Top Row Layout Block: Pipeline and Leaflet Map Aligned Together -->
    <div class="top-visualization-grid">
      <div class="visual-left-stack">
        <div class="kpi-strip" id="kpis"></div>
        <div>
          <div class="section-head"><h2>Review pipeline — status of development projects</h2></div>
          <div class="pipeline" id="pipeline"></div>
        </div>
      </div>
      
      <div class="map-panel">
        <h2>Project locations (OSM)</h2>
        <div class="map-sub">Real-time geographical pipeline map.</div>
        <div id="map-container"></div>
        <div class="map-legend">
          <div class="legend-item"><span class="legend-dot" style="background:#0F4C5C"></span>For HIA</div>
          <div class="legend-item"><span class="legend-dot" style="background:#7C3AED"></span>Exemption</div>
          <div class="legend-item"><span class="legend-dot" style="background:#059669"></span>M&E Issued</div>
          <div class="legend-item"><span class="legend-dot" style="background:#D97706"></span>Flagged</div>
